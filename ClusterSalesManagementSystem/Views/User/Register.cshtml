@model ClusterSalesManagementSystem.DTOs.RegisterDTO

@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<style>
    body {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        min-height: 100vh;
    }
</style>
<div class="container d-flex justify-content-center align-items-center" style="min-height: 90vh;">

    <div class="col-md-5">

        <div class="card shadow-lg" style="border-radius:15px;">

            <!-- HEADER -->
            <div class="card-header text-center"
                 style="background: linear-gradient(90deg,#4e73df,#224abe); color:white; border-radius:15px 15px 0 0;">

                <h4 class="mb-0">👤 Register User</h4>
            </div>

            <!-- BODY -->
            <div class="card-body p-4">

                <form asp-action="Register" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Username -->
                    <div class="form-group mb-3">
                        <label class="fw-semibold">User Name</label>
                        <input asp-for="UserName" class="form-control" placeholder="Enter username" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-group mb-3">
                        <label class="fw-semibold">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <!-- Role -->
                    <div class="form-group mb-3">
                        <label class="fw-semibold">User Role</label>
                        <select asp-for="UserRole" class="form-select">
                            <option value="">-- Select Role --</option>
                            <option value="Admin">Admin</option>
                            <option value="User">User</option>
                        </select>
                        <span asp-validation-for="UserRole" class="text-danger"></span>
                    </div>

                    <!-- BUTTONS -->
                    <div class="d-flex justify-content-between mt-4">

                        <button type="submit" class="btn btn-primary px-4">
                            Register
                        </button>
                        <a asp-action="Login" class="btn btn-outline-secondary">
                            ← Back to Login
                        </a>


                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
