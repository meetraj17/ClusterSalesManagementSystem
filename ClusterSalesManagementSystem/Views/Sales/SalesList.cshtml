@model IEnumerable<ClusterSalesManagementSystem.Models.Sales>

@{
    ViewData["Title"] = "SalesList";
}
@if (TempData["DeleteMessage"]!=null)
{
    <label class="alert-danger">@TempData["DeleteMessage"]</label>
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<h2>Sales List Page</h2>

<div class="card shadow-sm" style="border-radius:15px;">

    <!-- Header -->
    <div class="card-header d-flex justify-content-between align-items-center"
         style="background: linear-gradient(90deg,#4e73df,#224abe); color:white; border-radius:15px 15px 0 0;">

        <h5 class="mb-0">📊 Sales List</h5>

        <a asp-action="Create" class="btn btn-light btn-sm">
            ➕ Add Sales
        </a>
    </div>

    <!-- Body -->
    <div class="card-body">

        <table class="table table-hover align-middle text-center">

            <thead class="table-light">
                <tr>
                    <th>Amount</th>
                    <th>Cluster</th>
                    <th>Date</th>
                    <th style="width:170px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>

                        <!-- Amount -->
                        <td class="fw-semibold text-success">
                            ₹ @item.SalesAmount
                        </td>

                        <!-- Cluster -->
                        <td>
                            <span class="fw-semibold">
                                @item.cluster?.CluName
                            </span>
                        </td>

                        <!-- Date -->
                        <td>
                            @item.SalesDate.ToString("dd MMM yyyy")
                        </td>

                        <!-- Actions -->
                        <td>
                            <div class="d-flex justify-content-center gap-2">

                                <!-- Edit -->
                                <a asp-action="Create" asp-route-id="@item.SalesId"
                                   class="btn btn-warning btn-sm"
                                   title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <!-- Delete -->
                                <a asp-action="Delete" asp-route-id="@item.SalesId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Are you sure you want to delete this record?')"
                                   title="Delete">
                                    <i class="bi bi-trash-fill"></i>
                                </a>

                                <!-- View File -->
                            @*     <a href="@item.InvoiceUrl" target="_blank"
                                   class="btn btn-info btn-sm"
                                   title="View File">
                                    <i class="bi bi-eye-fill"></i>
                                </a> *@

                            </div>
                        </td>

                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>
