<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClusterSalesManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClusterSalesManagementSystem.styles.css" asp-append-version="true" />
</head>
<body style="background-color:#f4f6f9;">

    <!-- 🔹 NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background: linear-gradient(90deg, #4e73df, #224abe);">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-white" asp-controller="Home" asp-action="Index">
                    🚀 Cluster System
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Sales" asp-action="SalesList">📊 Sales</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Cluster" asp-action="ClusterList">🗺️ Cluster</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Report" asp-action="ReportView">Sales Report</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="User" asp-action="Logout">🚪 Logout</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- 🔹 MAIN CONTENT -->
    <div class="container mt-4">
        <main role="main">
            <div class="card shadow-sm p-4" style="border-radius: 15px;">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- 🔹 FOOTER -->
    <footer class="text-center text-muted mt-5 mb-3">
        <small>© 2026 Cluster Sales Management System | All Rights Reserved</small>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>


    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
